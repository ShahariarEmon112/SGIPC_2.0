# Root-level reference of environment variables used by the monorepo.
# Copy backend/.env.example to backend/.env and frontend/.env.local.example
# to frontend/.env.local, then fill in real values. Never commit the real files.

# === Backend (Laravel) — see backend/.env.example ===
# APP_KEY            generate with: php artisan key:generate
# DB_DATABASE        e.g. sgipc_db
# DB_USERNAME
# DB_PASSWORD
# MAIL_USERNAME      Gmail address for SMTP
# MAIL_PASSWORD      Gmail App Password (NOT your account password)
# CLOUDINARY_URL     cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME
# CLOUDINARY_API_KEY
# CLOUDINARY_API_SECRET
# FRONTEND_URL       http://localhost:3000

# === Frontend (Next.js) — see frontend/.env.local.example ===
# NEXT_PUBLIC_API_URL    http://localhost:8000/api
# NEXTAUTH_URL           http://localhost:3000
# NEXTAUTH_SECRET        openssl rand -base64 32
